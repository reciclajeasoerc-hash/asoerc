NODE_ENV=production

# Base de datos - Railway la inyecta automáticamente como DATABASE_URL
# (No necesitas configurar DB_HOST/DB_USER/etc si usas Railway MySQL)
DATABASE_URL=mysql://user:pass@host:port/dbname

# JWT - Genera una clave fuerte aleatoria (mínimo 32 caracteres)
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_SECRETA_MUY_LARGA
JWT_EXPIRES_IN=12h

# Superadmin inicial (se crea automáticamente al arrancar)
ADMIN_EMAIL=admin@asoerc.com
ADMIN_PASSWORD=CambiaEstaContraseña2024!

# Origen permitido (la URL de tu app en Railway)
ALLOWED_ORIGIN=https://asoerc-production.up.railway.app

# Puerto (Railway lo asigna automáticamente)
PORT=3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=tu_token_del_bot

# OpenAI (para transcripción de audios)
OPENAI_API_KEY=sk-...
